// =============================================
// WHATSAPP
// =============================================

model WhatsAppLog {
  id              String         @id @default(uuid())
  campaign_id     String?        @map("campaign_id")
  recipient_name  String?        @map("recipient_name")
  recipient_phone String         @map("recipient_phone")
  recipient_type  String?        @map("recipient_type") // apoiador, lideranca, equipe, outro
  template_name   String?        @map("template_name")
  message_content String?        @map("message_content")
  status          WhatsAppStatus @default(SENT)
  sent_by_id      String?        @map("sent_by_id")
  sent_by_name    String?        @map("sent_by_name")
  error_message   String?        @map("error_message")
  metadata        Json?

  // Timestamps
  created_at DateTime @default(now()) @map("created_at")
  updated_at DateTime @updatedAt @map("updated_at")

  // Relations
  campaign Campaign? @relation(fields: [campaign_id], references: [id])
  sent_by  User?     @relation("SentBy", fields: [sent_by_id], references: [id])

  @@index([campaign_id])
  @@index([sent_by_id])
  @@index([status])
  @@map("whatsapp_logs")
}

enum WhatsAppStatus {
  SENT
  DELIVERED
  READ
  FAILED
  PENDING
}

// =============================================
// FILES (Storage)
// =============================================

model File {
  id            String  @id @default(uuid())
  filename      String
  original_name String  @map("original_name")
  mime_type     String  @map("mime_type")
  size          Int
  path          String
  url           String?
  provider      String  @default("local") // local, minio, s3, r2
  uploaded_by   String? @map("uploaded_by")

  // Timestamps
  created_at DateTime  @default(now()) @map("created_at")
  updated_at DateTime  @updatedAt @map("updated_at")
  deleted_at DateTime? @map("deleted_at")

  // Relations
  user User? @relation(fields: [uploaded_by], references: [id])

  @@index([uploaded_by])
  @@map("files")
}

// =============================================
// SYSTEM CONFIG
// =============================================

model SystemConfig {
  id          String  @id @default(uuid())
  key         String  @unique
  value       Json
  description String?

  // Timestamps
  created_at DateTime @default(now()) @map("created_at")
  updated_at DateTime @updatedAt @map("updated_at")

  @@map("system_configs")
}
