// Prisma Schema — Plataforma Politica Esperancar
// Database: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================
// FOUNDATION V2 — ORGANIZATIONS
// =============================================

enum OrgPlan {
  free
  starter
  pro
  enterprise
}

enum OrgStatus {
  active
  suspended
  cancelled
}

model Organization {
  id       String    @id @default(uuid())
  name     String
  slug     String    @unique
  document String?
  address  String?
  phone    String?
  email    String?
  logo_url String?
  plan     OrgPlan   @default(free)
  status   OrgStatus @default(active)
  settings Json?     @default("{}")
  owner_id String?

  // Relations
  users       User[]
  campaigns   Campaign[]
  contacts    Contact[]
  demands     Demand[]
  missions    Mission[]
  teams       Team[]
  memberships Membership[]
  invitations Invitation[]
  audit_logs  AuditLog[]
  events      InternalEvent[]

  // Timestamps
  created_at             DateTime                 @default(now()) @map("created_at")
  updated_at             DateTime                 @updatedAt @map("updated_at")
  Notification           Notification[]
  NotificationPreference NotificationPreference[]

  @@index([slug])
  @@map("organizations")
}

model Membership {
  id              String    @id @default(uuid())
  user_id         String    @map("user_id")
  campaign_id     String?   @map("campaign_id")
  organization_id String?   @map("organization_id")
  role            String    @default("OPERATOR")
  permissions     Json?     @default("[]")
  territories     Json?     @default("[]")
  is_active       Boolean   @default(true)
  joined_at       DateTime  @default(now()) @map("joined_at")
  left_at         DateTime? @map("left_at")

  user     User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  campaign Campaign?     @relation(fields: [campaign_id], references: [id], onDelete: Cascade)
  org      Organization? @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([campaign_id])
  @@index([organization_id])
  @@map("memberships")
}

// =============================================
// FOUNDATION V2 — TEAMS & PERMISSIONS
// =============================================

model Team {
  id              String  @id @default(uuid())
  organization_id String  @map("organization_id")
  campaign_id     String? @map("campaign_id")
  name            String
  description     String?
  active          Boolean @default(true)
  created_by      String?

  created_at DateTime  @default(now()) @map("created_at")
  updated_at DateTime  @updatedAt @map("updated_at")
  deleted_at DateTime? @map("deleted_at")

  organization Organization?    @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  campaign     Campaign?        @relation(fields: [campaign_id], references: [id], onDelete: SetNull)
  members      TeamMembership[]

  @@index([organization_id])
  @@index([campaign_id])
  @@map("teams")
}

model TeamMembership {
  id        String    @id @default(uuid())
  team_id   String    @map("team_id")
  user_id   String    @map("user_id")
  role      String?   @default("MEMBER")
  active    Boolean   @default(true)
  joined_at DateTime  @default(now()) @map("joined_at")
  left_at   DateTime? @map("left_at")

  team Team @relation(fields: [team_id], references: [id], onDelete: Cascade)
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([team_id, user_id])
  @@index([user_id])
  @@map("team_memberships")
}

model Invitation {
  id              String    @id @default(uuid())
  organization_id String    @map("organization_id")
  campaign_id     String?   @map("campaign_id")
  email           String
  role            String    @default("OPERADOR")
  token_hash      String    @unique @map("token_hash")
  expires_at      DateTime  @map("expires_at")
  accepted_at     DateTime? @map("accepted_at")
  invited_by      String

  created_at DateTime @default(now()) @map("created_at")

  organization Organization? @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  campaign     Campaign?     @relation(fields: [campaign_id], references: [id], onDelete: SetNull)

  @@index([organization_id])
  @@index([email])
  @@map("invitations")
}

model RolePermission {
  id         String   @id @default(uuid())
  role       String
  permission String
  created_at DateTime @default(now()) @map("created_at")

  @@unique([role, permission])
  @@index([role])
  @@map("role_permissions")
}

enum AuditAction {
  create
  update
  delete
  login
  logout
  export
  import
  approve
  reject
}

model InternalEvent {
  id              String  @id @default(uuid())
  organization_id String? @map("organization_id")
  campaign_id     String? @map("campaign_id")
  user_id         String? @map("user_id")

  event_name       String    @map("event_name")
  event_version    Int       @default(1) @map("event_version")
  aggregate_type   String?   @map("aggregate_type")
  aggregate_id     String?   @map("aggregate_id")
  payload          Json?
  metadata         Json?
  correlation_id   String?   @map("correlation_id")
  request_id       String?   @map("request_id")
  occurred_at      DateTime  @default(now()) @map("occurred_at")
  processed_at     DateTime? @map("processed_at")
  processing_error String?   @map("processing_error")

  org           Organization?  @relation(fields: [organization_id], references: [id], onDelete: SetNull)
  campaign      Campaign?      @relation(fields: [campaign_id], references: [id], onDelete: SetNull)
  user          User?          @relation(fields: [user_id], references: [id], onDelete: SetNull)
  notifications Notification[]

  @@index([organization_id])
  @@index([campaign_id])
  @@index([event_name])
  @@index([aggregate_type, aggregate_id])
  @@index([correlation_id])
  @@index([request_id])
  @@index([occurred_at])
  @@map("internal_events")
}

// =============================================
// AUTH & USERS
// =============================================

model User {
  id            String     @id @default(uuid())
  email         String     @unique
  password_hash String     @map("password_hash")
  full_name     String     @map("full_name")
  phone         String?
  avatar_url    String?    @map("avatar_url")
  role          Role       @default(USER)
  profile       String? // extended role: coordenador, lideranca, operador
  status        UserStatus @default(ACTIVE)

  // Foundation V2 — organization + active campaign context
  organization_id    String? @map("organization_id")
  active_campaign_id String? @map("active_campaign_id")

  organization    Organization? @relation(fields: [organization_id], references: [id], onDelete: SetNull)
  active_campaign Campaign?     @relation("ActiveCampaign", fields: [active_campaign_id], references: [id], onDelete: SetNull)
  memberships     Membership[]

  // Preferences (stored in User for simplicity, could be separate table)
  lgpd_consent    Boolean @default(false) @map("lgpd_consent")
  notif_email     Boolean @default(true) @map("notif_email")
  sofia_enabled   Boolean @default(true) @map("sofia_enabled")
  ui_dark_mode    Boolean @default(false) @map("ui_dark_mode")
  whatsapp_status String? @map("whatsapp_status")
  metas           Json? // user metadata/goals

  // Timestamps
  created_at    DateTime  @default(now()) @map("created_at")
  updated_at    DateTime  @updatedAt @map("updated_at")
  last_login_at DateTime? @map("last_login_at")
  deleted_at    DateTime? @map("deleted_at")

  // Relations
  refresh_tokens           RefreshToken[]
  notifications            Notification[]
  notification_preferences NotificationPreference[]
  audit_logs               AuditLog[]
  sent_messages            WhatsAppLog[]            @relation("SentBy")
  files                    File[]
  team_memberships         TeamMembership[]
  internal_events          InternalEvent[]

  // Preferences
  @@index([active_campaign_id])
  @@map("users")
}

model RefreshToken {
  id         String    @id @default(uuid())
  user_id    String    @map("user_id")
  token      String    @unique
  expires_at DateTime  @map("expires_at")
  created_at DateTime  @default(now()) @map("created_at")
  revoked_at DateTime? @map("revoked_at")

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

enum Role {
  ADMIN
  COORDENADOR
  LIDERANCA
  OPERADOR
  FINANCEIRO
  COMUNICACAO
  LEITURA
  USER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  PENDING
  SUSPENDED
}

// =============================================
// CONTACTS
// =============================================

model Contact {
  id                       String        @id @default(uuid())
  full_name                String        @map("full_name")
  phone                    String?
  email                    String?
  cep                      String?
  city                     String?
  neighborhood             String?
  address_street           String?       @map("address_street")
  address_number           String?       @map("address_number")
  complement               String?       @map("complement")
  state                    String?       @map("state")
  electoral_zone           String?       @map("electoral_zone")
  electoral_section        String?       @map("electoral_section")
  voting_location          String?       @map("voting_location")
  position                 String?
  segment                  String?
  support_intent           String?       @map("support_intent") // apoiador, indeciso, contrario, lideranca_potencial
  contact_authorized       Boolean       @default(true) @map("contact_authorized")
  is_leader                Boolean       @default(false) @map("is_leader")
  vote_goal                Int           @default(0) @map("vote_goal")
  converted_by_leader_id   String?       @map("converted_by_leader_id")
  converted_by_leader_name String?       @map("converted_by_leader_name")
  engagement_level         Int           @default(50) @map("engagement_level")
  visual_no_carro          Boolean       @default(false) @map("visual_no_carro")
  visual_na_residencia     Boolean       @default(false) @map("visual_na_residencia")
  tags                     String[]      @default([])
  notes                    String?       @db.Text
  interactions             Json[]        @default([])
  latitude                 Float?
  longitude                Float?
  status                   ContactStatus @default(ACTIVE)

  // Audit
  created_by_leader_id   String? @map("created_by_leader_id")
  created_by_leader_name String? @map("created_by_leader_name")
  created_by_user_id     String? @map("created_by_user_id")
  assigned_to_id         String? @map("assigned_to_id")
  assigned_to_name       String? @map("assigned_to_name")

  // Foundation V2
  organization_id String? @map("organization_id")
  campaign_id     String? @map("campaign_id")

  org      Organization? @relation(fields: [organization_id], references: [id], onDelete: SetNull)
  campaign Campaign?     @relation(fields: [campaign_id], references: [id], onDelete: SetNull)

  // Timestamps
  created_at DateTime  @default(now()) @map("created_at")
  updated_at DateTime  @updatedAt @map("updated_at")
  deleted_at DateTime? @map("deleted_at")

  // Relations
  demands Demand[]

  @@index([full_name])
  @@index([city])
  @@index([neighborhood])
  @@index([status])
  @@index([is_leader])
  @@index([electoral_zone])
  @@index([organization_id])
  @@map("contacts")
}

enum ContactStatus {
  ACTIVE
  INACTIVE
  PENDING
}

// =============================================
// LEADERS
// =============================================

model Leader {
  id                 String       @id @default(uuid())
  name               String
  phone              String?
  email              String?
  city               String?
  neighborhood       String?
  electoral_zone     String?      @map("electoral_zone")
  supporters_count   Int          @default(0) @map("supporters_count")
  political_strength String?      @map("political_strength") // low, medium, high, very_high
  monthly_goal       Int          @default(0) @map("monthly_goal")
  conversions        Int          @default(0)
  actions_completed  Int          @default(0) @map("actions_completed")
  segment            String?
  notes              String?      @db.Text
  photo_url          String?      @map("photo_url")
  latitude           Float?
  longitude          Float?
  status             LeaderStatus @default(ACTIVE)

  // Timestamps
  created_at DateTime  @default(now()) @map("created_at")
  updated_at DateTime  @updatedAt @map("updated_at")
  deleted_at DateTime? @map("deleted_at")

  // Relations
  missions     Mission[]
  gamification GamificationProfile?

  @@index([name])
  @@index([city])
  @@index([status])
  @@map("leaders")
}

enum LeaderStatus {
  ACTIVE
  INACTIVE
}

// =============================================
// DEMANDS
// =============================================

model Demand {
  id              String         @id @default(uuid())
  title           String
  protocol        String?        @unique
  type            DemandType
  description     String?        @db.Text
  requester_name  String?        @map("requester_name")
  requester_phone String?        @map("requester_phone")
  requester_email String?        @map("requester_email")
  cep             String?        @map("cep")
  address         String?
  city            String?
  neighborhood    String?
  latitude        Float?
  longitude       Float?
  priority        DemandPriority @default(MEDIUM)
  status          DemandStatus   @default(OPEN)
  responsible     String?
  due_date        DateTime?      @map("due_date")
  closed_date     DateTime?      @map("closed_date")
  photo_url       String?        @map("photo_url")

  // Relations
  supporter_id           String? @map("supporter_id")
  supporter_name         String? @map("supporter_name")
  created_by_leader_id   String? @map("created_by_leader_id")
  created_by_leader_name String? @map("created_by_leader_name")
  created_by_user_id     String? @map("created_by_user_id")

  // Foundation V2
  organization_id String? @map("organization_id")
  campaign_id     String? @map("campaign_id")

  org      Organization? @relation(fields: [organization_id], references: [id], onDelete: SetNull)
  campaign Campaign?     @relation(fields: [campaign_id], references: [id], onDelete: SetNull)

  // History
  history Json[] @default([])

  // Timestamps
  created_at DateTime  @default(now()) @map("created_at")
  updated_at DateTime  @updatedAt @map("updated_at")
  deleted_at DateTime? @map("deleted_at")

  // Relations
  contact Contact? @relation(fields: [supporter_id], references: [id])

  @@index([status])
  @@index([type])
  @@index([priority])
  @@index([city])
  @@index([neighborhood])
  @@index([due_date])
  @@map("demands")
}

enum DemandType {
  HEALTH
  EDUCATION
  INFRASTRUCTURE
  ZELADORIA
  ILUMINACAO
  TRANSPORT
  SOCIAL
  SECURITY
  HOUSING
  EMPLOYMENT
  DOCUMENTACAO
  OTHER
}

enum DemandPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum DemandStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  PENDING
  CANCELLED
}

// =============================================
// MISSIONS
// =============================================

model Mission {
  id                   String          @id @default(uuid())
  title                String
  description          String?         @db.Text
  type                 MissionType
  neighborhood         String?
  city                 String?
  leader_id            String?         @map("leader_id")
  leader_name          String?         @map("leader_name")
  deadline             DateTime?
  priority             MissionPriority @default(MEDIUM)
  points               Int             @default(30)
  status               MissionStatus   @default(PENDING)
  evidence             String?         @db.Text
  evidence_url         String?         @map("evidence_url")
  completed_date       DateTime?       @map("completed_date")
  notified_at          DateTime?       @map("notified_at")
  reminded_at          DateTime?       @map("reminded_at")
  congratulated_at     DateTime?       @map("congratulated_at")
  parent_mission_id    String?         @map("parent_mission_id")
  is_group_mission     Boolean         @default(false) @map("is_group_mission")
  assignment_type      String?         @map("assignment_type") // individual, neighborhood_group, segment_group, all, custom_filters
  assignment_filters   Json?           @map("assignment_filters")
  total_recipients     Int             @default(0) @map("total_recipients")
  completed_recipients Int             @default(0) @map("completed_recipients")
  segment              String?
  checklist            Json[]          @default([])

  // Audit
  created_by_user_id String? @map("created_by_user_id")

  // Foundation V2
  organization_id String? @map("organization_id")
  campaign_id     String? @map("campaign_id")

  org      Organization? @relation(fields: [organization_id], references: [id], onDelete: SetNull)
  campaign Campaign?     @relation(fields: [campaign_id], references: [id], onDelete: SetNull)

  // Timestamps
  created_at DateTime  @default(now()) @map("created_at")
  updated_at DateTime  @updatedAt @map("updated_at")
  deleted_at DateTime? @map("deleted_at")

  // Relations
  leader Leader? @relation(fields: [leader_id], references: [id])

  @@index([status])
  @@index([leader_id])
  @@index([deadline])
  @@index([type])
  @@map("missions")
}

enum MissionType {
  REGISTER_SUPPORTERS
  VISIT_REGION
  MOBILIZE_MEETING
  COLLECT_DEMANDS
  CONFIRM_ATTENDANCE
  SHARE_CONTENT
  ORGANIZE_LOCAL_NUCLEUS
  UPDATE_TERRITORIAL_DATA
  FORWARD_SERVICE
  OTHER
}

enum MissionPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum MissionStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  OVERDUE
  CANCELLED
}

// =============================================
// GAMIFICATION
// =============================================

model GamificationProfile {
  id                    String    @id @default(uuid())
  leader_id             String    @unique @map("leader_id")
  leader_name           String    @map("leader_name")
  neighborhood          String?
  city                  String?
  total_points          Int       @default(0) @map("total_points")
  current_level         String    @default("semente") // semente, mobilizador, lideranca_local, coordenador_territorial, referencia_esperancar
  badges                String[]  @default([])
  missions_completed    Int       @default(0) @map("missions_completed")
  missions_pending      Int       @default(0) @map("missions_pending")
  missions_overdue      Int       @default(0) @map("missions_overdue")
  supporters_registered Int       @default(0) @map("supporters_registered")
  leaders_converted     Int       @default(0) @map("leaders_converted")
  visual_carros         Int       @default(0) @map("visual_carros")
  visual_residencias    Int       @default(0) @map("visual_residencias")
  demands_resolved      Int       @default(0) @map("demands_resolved")
  vote_goal             Int       @default(0) @map("vote_goal")
  votes_achieved        Int       @default(0) @map("votes_achieved")
  weekly_points         Int       @default(0) @map("weekly_points")
  monthly_points        Int       @default(0) @map("monthly_points")
  last_level_up_at      DateTime? @map("last_level_up_at")
  last_activity_at      DateTime? @map("last_activity_at")
  week_start            DateTime? @map("week_start")
  month_start           DateTime? @map("month_start")

  // Timestamps
  created_at DateTime @default(now()) @map("created_at")
  updated_at DateTime @updatedAt @map("updated_at")

  // Relations
  leader Leader @relation(fields: [leader_id], references: [id], onDelete: Cascade)

  @@index([total_points])
  @@index([current_level])
  @@map("gamification_profiles")
}

// =============================================
// CAMPAIGNS
// =============================================

model Campaign {
  id                     String            @id @default(uuid())
  name                   String
  type                   CampaignType      @default(MUNICIPAL)
  year                   Int?
  position               CampaignPosition?
  candidate_name         String?           @map("candidate_name")
  party                  String?
  coalition              String?
  vote_goal              Int               @default(0) @map("vote_goal")
  current_votes_estimate Int               @default(0) @map("current_votes_estimate")
  budget                 Float             @default(0)
  status                 CampaignStatus    @default(PLANNING)
  start_date             DateTime?         @map("start_date")
  end_date               DateTime?         @map("end_date")

  // Foundation V2
  organization_id String? @map("organization_id")
  settings        Json?   @default("{}")
  created_by      String?

  organization Organization?   @relation(fields: [organization_id], references: [id], onDelete: SetNull)
  active_users User[]          @relation("ActiveCampaign")
  memberships  Membership[]
  teams        Team[]
  invitations  Invitation[]
  contacts     Contact[]
  demands      Demand[]
  missions     Mission[]
  audit_logs   AuditLog[]
  events       InternalEvent[]

  // Timestamps
  created_at DateTime  @default(now()) @map("created_at")
  updated_at DateTime  @updatedAt @map("updated_at")
  deleted_at DateTime? @map("deleted_at")

  // Relations
  whatsapp_logs WhatsAppLog[]
  Notification  Notification[]

  @@index([status])
  @@index([year])
  @@index([organization_id])
  @@map("campaigns")
}

enum CampaignType {
  MUNICIPAL
  STATE
  FEDERAL
}

enum CampaignPosition {
  MAYOR
  COUNCILOR
  GOVERNOR
  STATE_DEPUTY
  FEDERAL_DEPUTY
  SENATOR
  PRESIDENT
}

enum CampaignStatus {
  PLANNING
  ACTIVE
  FINISHED
}

// =============================================
// STRATEGIC ACTIONS
// =============================================

model StrategicAction {
  id             String                @id @default(uuid())
  title          String
  description    String?               @db.Text
  type           StrategicActionType   @default(EVENT)
  city           String?
  neighborhood   String?
  start_date     DateTime?             @map("start_date")
  end_date       DateTime?             @map("end_date")
  responsible    String?
  goal           String?               @db.Text
  expected_reach Int                   @default(0) @map("expected_reach")
  actual_reach   Int                   @default(0) @map("actual_reach")
  status         StrategicActionStatus @default(PLANNED)
  budget         Float                 @default(0)
  notes          String?               @db.Text

  // Audit
  created_by_user_id String? @map("created_by_user_id")

  // Timestamps
  created_at DateTime  @default(now()) @map("created_at")
  updated_at DateTime  @updatedAt @map("updated_at")
  deleted_at DateTime? @map("deleted_at")

  @@index([status])
  @@index([type])
  @@map("strategic_actions")
}

enum StrategicActionType {
  EVENT
  CAMPAIGN
  VISIT
  MEETING
  TRAINING
  OTHER
}

enum StrategicActionStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// =============================================
// NOTIFICATIONS
// =============================================

model Notification {
  id              String           @id @default(uuid())
  organization_id String?          @map("organization_id")
  campaign_id     String?          @map("campaign_id")
  event_id        String?          @map("event_id")
  user_id         String           @map("user_id")
  title           String
  message         String           @db.Text
  type            NotificationType @default(INFO)
  entity_type     String?          @map("entity_type")
  entity_id       String?          @map("entity_id")
  action_url      String?          @map("action_url")
  metadata        Json?
  read_at         DateTime?        @map("read_at")
  expires_at      DateTime?        @map("expires_at")
  created_at      DateTime         @default(now()) @map("created_at")

  user     User           @relation(fields: [user_id], references: [id], onDelete: Cascade)
  org      Organization?  @relation(fields: [organization_id], references: [id], onDelete: SetNull)
  campaign Campaign?      @relation(fields: [campaign_id], references: [id], onDelete: SetNull)
  event    InternalEvent? @relation(fields: [event_id], references: [id], onDelete: SetNull)

  @@unique([event_id, user_id, type])
  @@index([user_id])
  @@index([organization_id])
  @@index([campaign_id])
  @@index([event_id])
  @@index([read_at])
  @@index([created_at])
  @@map("notifications")
}

enum NotificationType {
  DEMAND_OVERDUE
  MISSION_OVERDUE
  MISSION_ASSIGNED
  LEVEL_UP
  SYSTEM
  INFO
}

model NotificationPreference {
  id              String   @id @default(uuid())
  organization_id String?  @map("organization_id")
  user_id         String   @map("user_id")
  event_name      String   @map("event_name")
  in_app          Boolean  @default(true) @map("in_app")
  email           Boolean  @default(false)
  whatsapp        Boolean  @default(false)
  created_at      DateTime @default(now()) @map("created_at")
  updated_at      DateTime @updatedAt @map("updated_at")

  org  Organization? @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  user User          @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([organization_id, user_id, event_name])
  @@index([user_id])
  @@index([event_name])
  @@map("notification_preferences")
}

// =============================================
// AUDIT LOG
// =============================================

model AuditLog {
  id              String        @id @default(uuid())
  organization_id String?       @map("organization_id")
  campaign_id     String?       @map("campaign_id")
  user_id         String?       @map("user_id")
  user_name       String?
  action          String
  entity          String
  entity_id       String?       @map("entity_id")
  entity_label    String?
  changes         Json?
  ip_address      String?       @map("ip_address")
  user_agent      String?       @map("user_agent")
  module          String?
  severity        AuditSeverity @default(INFO)
  metadata        Json?

  // Timestamps
  created_at DateTime @default(now()) @map("created_at")

  // Relations
  org      Organization? @relation(fields: [organization_id], references: [id], onDelete: SetNull)
  campaign Campaign?     @relation(fields: [campaign_id], references: [id], onDelete: SetNull)
  user     User?         @relation(fields: [user_id], references: [id])

  @@index([entity])
  @@index([action])
  @@index([user_id])
  @@index([organization_id])
  @@index([created_at])
  @@map("audit_logs")
}

enum AuditSeverity {
  INFO
  WARNING
  ERROR
  CRITICAL
}

// =============================================
// ELECTORAL DATA
// =============================================

model ElectoralData {
  id                String  @id @default(uuid())
  city              String
  neighborhood      String
  electoral_zone    String? @map("electoral_zone")
  electoral_section String? @map("electoral_section")
  voting_location   String? @map("voting_location")
  year              Int?
  position          String?
  candidate_name    String? @map("candidate_name")
  votes             Int     @default(0)
  total_voters      Int     @default(0) @map("total_voters")
  latitude          Float?
  longitude         Float?
  heat_level        String? @map("heat_level") // cold, warm, hot

  // Timestamps
  created_at DateTime @default(now()) @map("created_at")
  updated_at DateTime @updatedAt @map("updated_at")

  @@index([city])
  @@index([neighborhood])
  @@index([year])
  @@map("electoral_data")
}

// =============================================
