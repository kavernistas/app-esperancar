model TSEImportJob {
  id                           String    @id @default(uuid())
  ano                          Int
  uf                           String
  municipio                    String?
  dataset_tipo                 String    @map("dataset_tipo")
  file_url                     String    @map("file_url")
  csv_cache_url                String?   @map("csv_cache_url")
  status                       String    @default("pendente")
  progresso                    Int       @default(0)
  total_linhas_arquivo         Int       @default(0) @map("total_linhas_arquivo")
  linhas_processadas           Int       @default(0) @map("linhas_processadas")
  registros_importados         Int       @default(0) @map("registros_importados")
  registros_duplicados         Int       @default(0) @map("registros_duplicados")
  linha_offset                 Int       @default(0) @map("linha_offset")
  velocidade_registros_segundo Int       @default(0) @map("velocidade_registros_segundo")
  tempo_estimado_segundos      Int       @default(0) @map("tempo_estimado_segundos")
  inicio                       DateTime?
  fim                          DateTime?
  ultima_atividade             DateTime? @map("ultima_atividade")
  erro                         String?
  etapa                        String    @default("baixando")
