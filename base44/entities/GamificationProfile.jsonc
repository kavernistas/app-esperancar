{
  "name": "GamificationProfile",
  "type": "object",
  "properties": {
    "leader_id": {
      "type": "string",
      "description": "ID da lideran\u00e7a"
    },
    "leader_name": {
      "type": "string"
    },
    "neighborhood": {
      "type": "string"
    },
    "city": {
      "type": "string"
    },
    "total_points": {
      "type": "number",
      "default": 0
    },
    "current_level": {
      "type": "string",
      "enum": [
        "semente",
        "mobilizador",
        "lideranca_local",
        "coordenador_territorial",
        "referencia_esperancar"
      ],
      "default": "semente"
    },
    "badges": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "missions_completed": {
      "type": "number",
      "default": 0
    },
    "missions_pending": {
      "type": "number",
      "default": 0
    },
    "missions_overdue": {
      "type": "number",
      "default": 0
    },
    "supporters_registered": {
      "type": "number",
      "default": 0
    },
    "leaders_converted": {
      "type": "number",
      "default": 0,
      "description": "Quantas lideran\u00e7as converteu"
    },
    "visual_carros": {
      "type": "number",
      "default": 0,
      "description": "Visuais de carro distribu\u00eddos"
    },
    "visual_residencias": {
      "type": "number",
      "default": 0,
      "description": "Visuais de resid\u00eancia distribu\u00eddos"
    },
    "demands_resolved": {
      "type": "number",
      "default": 0
    },
    "weekly_points": {
      "type": "number",
      "default": 0
    },
    "monthly_points": {
      "type": "number",
      "default": 0
    },
    "last_level_up_at": {
      "type": "string"
    },
    "last_activity_at": {
      "type": "string"
    },
    "week_start": {
      "type": "string",
      "format": "date"
    },
    "month_start": {
      "type": "string",
      "format": "date"
    }
  },
  "required": [
    "leader_id"
  ]
}